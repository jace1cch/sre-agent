# 閼垫崘顔嗘禍?CVM 閸楁洘婧€閻?SRE Agent 闁板秶鐤嗗Ο鈩冩緲
# 闁倻鏁ら崷鐑樻珯閿? 閺?2G閿涘苯宕熼張?Docker Java 鎼存梻鏁ら敍瀛竐bhook 閸涘﹨顒?

# 濡€崇€烽柊宥囩枂
MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
REPOSITORY_PATH=/opt/your-java-app

# 瀹糕剝顥呮０鎴犲芳
CHECK_INTERVAL_SECONDS=60

# 娑撶粯婧€闂冨牆鈧?
HOST_DISK_PATH=/
CPU_PERCENT_THRESHOLD=75
MEMORY_AVAILABLE_THRESHOLD_MB=384
DISK_THRESHOLD_PERCENT=85
LOAD_THRESHOLD_PER_CORE=0.85

# 鐎圭懓娅掓稉?JVM
APP_CONTAINER_NAME=java-app
APP_CONTAINER_NAMES=java-app,java-worker
APP_LOG_SINCE_SECONDS=300
CONTAINER_RESTART_THRESHOLD=0
ERROR_BURST_THRESHOLD=5
FULL_GC_THRESHOLD=1
JAVA_DIAG_MODE=sigquit

# 娑撴艾濮熺仦鍌炴閸?
WORKFLOW_TIMEOUT_SECONDS=300
WORKFLOW_FAILURE_RATE_THRESHOLD=0.15
TOKEN_ANOMALY_THRESHOLD=20000
TOOL_FAILURE_RATE_THRESHOLD=0.20

# 闁氨鐓?
WEBHOOK_URL=
WEBHOOK_PROVIDER=feishu
WEBHOOK_TIMEOUT_SECONDS=10

# 閼奉亜濮╂径鍕枂
AUTO_REMEDIATE=false
LOG_RETENTION_DAYS=30
LOG_CLEAN_PATHS=/var/log/your-app,/data/logs
WORKFLOW_CANCEL_URL=
WORKFLOW_CANCEL_TOKEN=

# 閽€鐣屾磸
INCIDENT_STORE_PATH=/opt/sre-agent/data/incidents.jsonl

# Autonomous graph framework
GRAPH_ENABLE_AUTONOMOUS_LOOP=true
GRAPH_MAX_STEPS=4
CODEBASE_PATH=/opt/your-java-app
CODEBASE_FETCH_MODE=local
CODEBASE_GIT_URL=
CODEBASE_GIT_BRANCH=main
CODEBASE_CACHE_PATH=/opt/sre-agent/.cache/codebase
PROMETHEUS_BASE_URL=
PROMETHEUS_TIMEOUT_SECONDS=5
PROMETHEUS_STEP_SECONDS=60
